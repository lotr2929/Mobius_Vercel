{
  "version": 2,
  "routes": [
    {"src": "/orchestrate",              "dest": "/api/orchestrate"},
    {"src": "/codeindex",                  "dest": "/api/index"},
    {"src": "/api/services/status",       "dest": "/api/status"},
    {"src": "/api/health",               "dest": "/api/health"},
    {"src": "/api/data",                 "dest": "/api/data"},
    {"src": "/ask",                      "dest": "/api/query/[action]?action=ask"},
    {"src": "/memory",                    "dest": "/api/query/[action]?action=memory"},
    {"src": "/agent",                    "dest": "/api/agent"},
    {"src": "/(.*)",                     "dest": "/$1"}
  ]
}
