{
  "version": 2,
  "routes": [
    {"src": "/auth/google/callback",  "dest": "/api/auth/[service]?service=google&action=callback"},
    {"src": "/auth/google/status",    "dest": "/api/auth/[service]?service=google&action=status"},
    {"src": "/auth/google",           "dest": "/api/auth/[service]?service=google&action=index"},
    {"src": "/auth/dropbox/callback", "dest": "/api/auth/[service]?service=dropbox&action=callback"},
    {"src": "/auth/dropbox",          "dest": "/api/auth/[service]?service=dropbox&action=index"},
    {"src": "/ask",                   "dest": "/api/query/[action]?action=ask"},
    {"src": "/parse",                 "dest": "/api/query/[action]?action=parse"},
    {"src": "/upload",                "dest": "/api/data?action=upload"},
    {"src": "/api/chat-history",      "dest": "/api/data?action=history"},
    {"src": "/api/login",             "dest": "/api/auth/[service]?service=user&action=login"},
    {"src": "/api/signup",            "dest": "/api/auth/[service]?service=user&action=signup"},
    {"src": "/api/google/info",       "dest": "/api/services/[action]?action=info"},
    {"src": "/api/google/accounts",   "dest": "/api/services/[action]?action=accounts"},
    {"src": "/api/google/disconnect", "dest": "/api/services/[action]?action=disconnect"},
    {"src": "/api/dropbox",           "dest": "/api/services/[action]?action=dropbox"},
    {"src": "/api/dropbox/list",      "dest": "/api/services/[action]?action=dropbox-list"},
    {"src": "/api/focus/find",           "dest": "/api/data?action=focus-find"},
    {"src": "/api/focus/read",           "dest": "/api/data?action=focus-read"},
    {"src": "/api/focus/copy",           "dest": "/api/data?action=focus-copy"},
    {"src": "/api/focus/create-or-update","dest": "/api/data?action=focus-create-or-update"},
    {"src": "/api/focus/create",         "dest": "/api/data?action=focus-create"},
    {"src": "/api/focus/append",         "dest": "/api/data?action=focus-append"},
    {"src": "/api/focus/update-original","dest": "/api/data?action=focus-update-original"},
    {"src": "/api/knowledge/save",       "dest": "/api/data?action=knowledge-save"},
    {"src": "/api/knowledge/query",      "dest": "/api/data?action=knowledge-query"},
    {"src": "/api/sessions/start",       "dest": "/api/data?action=sessions-start"},
    {"src": "/api/sessions/end",         "dest": "/api/data?action=sessions-end"},
    {"src": "/api/sessions/last",        "dest": "/api/data?action=sessions-last"},
    {"src": "/api/model-config/save",    "dest": "/api/data?action=model-config-save"},
    {"src": "/api/model-config/get",     "dest": "/api/data?action=model-config-get"},
    {"src": "/api/sync/status",       "dest": "/api/data?action=sync-status"},
    {"src": "/api/sync",              "dest": "/api/data?action=sync"},
    {"src": "/api/services/status",   "dest": "/api/services/[action]?action=status"},
    {"src": "/login",                 "dest": "/login.html"},
    {"src": "/signup",                "dest": "/signup.html"},
    {"src": "/help/(.*)",             "dest": "/help/$1"},
    {"src": "/(.*)",                  "dest": "/$1"}
  ]
}
