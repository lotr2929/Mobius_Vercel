<script>
    const TOTAL = 15; // pages 0-14
    let current = 0;

    function goTo(n) {
        const nav = document.querySelector('.nav');
        nav.classList.toggle('nav-hidden', n === 0);
        document.getElementById('page-' + current).classList.remove('active');
        current = n;
        document.getElementById('page-' + current).classList.add('active');
        document.getElementById('btnPrev').disabled = current === 0;
        document.getElementById('btnNext').disabled = current === TOTAL - 1;
        window.scrollTo(0, 0);
        return false;
    }

    function navigate(dir) {
        const next = current + dir;
        if (next >= 0 && next < TOTAL) goTo(next);
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight') navigate(1);
        if (e.key === 'ArrowLeft')  navigate(-1);
    });
</script>

