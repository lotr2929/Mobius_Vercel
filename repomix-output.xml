            padding: 8px 10px;
            background: #ede5d4;
            border: 1px solid #c9bfae;
            border-radius: 1px;
            margin-bottom: 6px;
            cursor: pointer;
            transition: background 0.15s;
            user-select: none;
        }
        .chat-history-item:hover { background: #d9cfbc; }
        .chi-title { font-weight: bold; color: #3a2e22; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .chi-meta { font-size: 11px; color: #8d7c64; margin-top: 2px; }

        /* Context menu */
        #contextMenu {
            position: fixed;
            background: #f5eedd;
            border: 1px solid #8d7c64;
            border-radius: 2px;
            box-shadow: 2px 4px 10px rgba(0,0,0,0.15);
            z-index: 9999;
            min-width: 180px;
            display: none;
        }
        .ctx-item { padding: 8px 14px; font-size: 14px; color: #3a2e22; cursor: pointer; font-family: inherit; }
        .ctx-item:hover { background: #d9cfbc; }

        /* Image thumbnails */
        .img-thumb { max-width: 100%; max-height: 180px; border: 1px solid #c9bfae; margin-top: 6px; border-radius: 1px; }

        /* Response toolbar */
        .resp-toolbar {
            display: flex;
            align-items: center;
            gap: 4px;
            margin-top: 6px;
            padding-top: 4px;
        }
        .resp-btn {
            background: transparent;
            border: none;
            cursor: pointer;
            font-size: 13px;
            color: #b8a898;
            padding: 2px 4px;
            border-radius: 2px;
            height: 22px;
            line-height: 1;
            font-family: inherit;
            transition: color 0.15s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            vertical-align: middle;
        }
        .resp-btn:hover { color: #4a3728; background: transparent; }
        .resp-btn svg { display: block; }
        .resp-btn.active-up   { color: #4a7c4e; }
        .resp-btn.active-down { color: #8d3a3a; }
    </style>
</head>
<body>
    <!-- Header -->
    <div style="display:flex; align-items:center; gap:4px; margin-bottom:1px; flex-wrap:nowrap;">
        <img src="mobius-logo.png" alt="Mobius Logo" style="height:60px; flex-shrink:0;">
        <h1 style="margin:0; font-size:30px; flex-shrink:0;">Mobius</h1>
        <!-- Desktop: single row; Mobile: two rows -->
        <div id="headerRight" style="margin-left:auto; display:flex; flex-wrap:wrap; align-items:center; gap:6px; justify-content:flex-end;">
            <span id="userLabel" style="font-size:14px; color:#4a3728; white-space:nowrap;"></span>
            <span id="googleDot" title="Google not connected — type 'status' for details" style="display:none; width:8px; height:8px; background:#c07800; border-radius:50%; flex-shrink:0; cursor:default;"></span>
            <span id="syncIndicator" title="Sync status" style="font-size:11px; color:#8d7c64; white-space:nowrap; cursor:default;"></span>
            <div style="display:flex; gap:6px; flex-shrink:0;">
                <a href="/help" target="_blank" style="font-size:13px; color:#8d7c64; text-decoration:none; border:1px solid #8d7c64; padding:2px 8px; border-radius:1px; white-space:nowrap;">Help</a>
                <button onclick="logout()" style="font-size:13px; background:transparent; color:#8d7c64; border:1px solid #8d7c64; padding:2px 8px; border-radius:1px; cursor:pointer; height:auto; white-space:nowrap;">Log Out</button>
            </div>
        </div>
    </div>

    <textarea id="input" placeholder="Ask something..." rows="3"></textarea>
    <div id="fileChips"></div>

    <!-- Toolbar -->
    <div class="controls">
        <button id="uploadBtn" title="Attach file" onclick="document.getElementById('fileInput').click()">
            <svg viewBox="0 0 26 26" fill="#8d7c64" xmlns="http://www.w3.org/2000/svg">
                <rect x="9.5" y="2" width="7" height="22"/>
                <rect x="2" y="9.5" width="22" height="7"/>
            </svg>
        </button>
        <input type="file" id="fileInput" style="display:none" multiple accept="image/*,.pdf,.txt,.md,.csv,.js,.py,.html,.json" onchange="handleFileSelect(this)">
        <button id="askBtn" onclick="handleAsk()">Ask</button>
        <div style="display:flex; gap:1px; align-items:center; height:31px; flex-shrink:0; margin-right:7px;">
            <button onclick="navigateChat(-1)" title="Previous query" style="width:30px; height:38px; background:transparent; border:none; cursor:pointer; padding:0; display:flex; align-items:center; justify-content:center;">
                <svg width="30" height="38" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><polygon points="10,0 20,20 0,20" fill="#8d7c64"/></svg>
            </button>
            <button onclick="navigateChat(1)" title="Next query" style="width:30px; height:38px; background:transparent; border:none; cursor:pointer; padding:0; display:flex; align-items:center; justify-content:center;">
                <svg width="30" height="38" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><polygon points="10,20 20,0 0,0" fill="#8d7c64"/></svg>
            </button>
        </div>
        <input id="chatSearch" type="text" placeholder="Search..." oninput="searchChat(this.value)"
            style="height:31px; padding:0 8px; font-size:14px; border:1px solid #8d7c64; background:#f5eedd; color:#4a3728; border-radius:1px; flex:1; min-width:0; box-sizing:border-box;">
    </div>

    <div id="chatPanel"></div>

    <!-- Context menu -->
    <div id="contextMenu">
        <div class="ctx-item" onclick="ctxAction('load')">📂 Open chat</div>
        <div class="ctx-item" onclick="ctxAction('copy-summary')">📋 Copy summary</div>
        <div class="ctx-item" onclick="ctxAction('copy-full')">📄 Copy full chat</div>
        <div class="ctx-item" onclick="ctxAction('copy-context')">💬 Copy as context</div>
    </div>

    <script>
        // ── Auth helpers ──────────────────────────────────────────────────────
        function logout() {
            ['mobius_user_id','mobius_username','mobius_google_connected','mobius_google_attempted'].forEach(k => {
                localStorage.removeItem(k);
                sessionStorage.removeItem(k);
                document.cookie = k + '=; Max-Age=0; Path=/; SameSite=Lax';
                document.cookie = k + '=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/';
            });
            window.location.href = '/login';
        }
        function getCookie(name) {
            const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
            return match ? decodeURIComponent(match[2]) : null;
        }
        function getAuth(key) {
            return localStorage.getItem(key) || sessionStorage.getItem(key) || getCookie(key) || null;
        }

        // ── Google dot: updated by status command and startup ping ──────────────────────
        function updateGoogleDot(connected) {
            const dot = document.getElementById('googleDot');
            if (!dot) return;
            dot.style.display = connected ? 'none' : 'inline-block';
        }
        window.updateGoogleDot = updateGoogleDot;

        // Silent startup ping — check personal Google connection status
        (async () => {
            try {
                const uid = getAuth('mobius_user_id');
                if (!uid) return;
                const res  = await fetch('/api/google/accounts?userId=' + encodeURIComponent(uid), { signal: AbortSignal.timeout(5000) });
                const data = await res.json();
                updateGoogleDot(!!(data.accounts && data.accounts.length > 0));
            } catch { /* silent — don't surface startup errors */ }
        })();
        function setAuth(key, value) {
            try { localStorage.setItem(key, value); } catch(e) {}
            try { sessionStorage.setItem(key, value); } catch(e) {}
        }

        // Restore session from cookie/sessionStorage if localStorage was cleared (mobile PWA)
        if (!localStorage.getItem('mobius_user_id')) {
            const id = getCookie('mobius_user_id') || sessionStorage.getItem('mobius_user_id');
            const un = getCookie('mobius_username') || sessionStorage.getItem('mobius_username');
            if (id) { setAuth('mobius_user_id', id); setAuth('mobius_username', un); }
        }
        if (!getAuth('mobius_user_id')) {
            window.location.href = '/login';
        } else {
            document.getElementById('userLabel').textContent = 'User: ' + getAuth('mobius_username');
        }

        // ── Event listeners ───────────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', () => {
            const textarea = document.getElementById('input');
            textarea.addEventListener('input', () => {
                textarea.style.height = 'auto';
                textarea.style.height = textarea.scrollHeight + 'px';
            });
            textarea.addEventListener('keydown', e => {
                if (e.key === 'Enter' && e.ctrlKey) handleAsk();
                if (e.key === 'Escape') globalEscape();
                // ↑/↓ history — only when cursor is on first/last line
                if (e.key === 'ArrowUp' || e.key === 'ArrowDown') {
                    const val   = textarea.value;
                    const lines = val.split('\n');
                    const pos   = textarea.selectionStart;
                    const onFirstLine = pos <= val.indexOf('\n') || lines.length === 1;
                    const onLastLine  = pos >= val.lastIndexOf('\n') + 1 || lines.length === 1;
                    if (!inputHistory.length) return;
                    if (e.key === 'ArrowUp' && onFirstLine) {
                        e.preventDefault();
                        if (inputHistIdx === -1) inputHistDraft = textarea.value;
                        inputHistIdx = Math.min(inputHistIdx + 1, inputHistory.length - 1);
                        textarea.value = inputHistory[inputHistIdx];
                        textarea.style.height = 'auto';
                        textarea.style.height = textarea.scrollHeight + 'px';
                        textarea.setSelectionRange(0, 0);
                    } else if (e.key === 'ArrowDown' && onLastLine) {
                        e.preventDefault();
                        if (inputHistIdx <= 0) {
                            inputHistIdx = -1;
                            textarea.value = inputHistDraft;
                        } else {
                            inputHistIdx--;
                            textarea.value = inputHistory[inputHistIdx];
                        }
                        textarea.style.height = 'auto';
                        textarea.style.height = textarea.scrollHeight + 'px';
                        const end = textarea.value.length;
                        textarea.setSelectionRange(end, end);
                    }
                }
            });
        });
        document.addEventListener('click', () => hideContextMenu());

        // ── State ─────────────────────────────────────────────────────────────
        let chatHistory      = [];   // in-session message history sent to AI
        let pendingMobiusQuery = null;
        let attachedFiles    = [];
        let ctxSession       = null;
        let currentNavIndex  = -1;

        // ── Session ID ────────────────────────────────────────────────────────
        // UUID generated once per page load; reset on New: command
        // Exposed globally so commands.js Code: calls can include it
        function generateSessionId() {
            return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {
                const r = Math.random() * 16 | 0;
                return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
            });
        }
        let currentSessionId = generateSessionId();
        window.getCurrentSessionId = () => currentSessionId;

        // ── Input history (PowerShell-style ↑/↓, persisted to localStorage) ─────────
        const inputHistory   = JSON.parse(localStorage.getItem('mobius_input_history') || '[]');
        let   inputHistIdx   = -1;
        let   inputHistDraft = '';
        function saveInputHistory() {
            try { localStorage.setItem('mobius_input_history', JSON.stringify(inputHistory.slice(0, 100))); } catch(e) {}
        }

        // ── Global Esc handler ───────────────────────────────────────────────────────────────
        function globalEscape() {
            // 1. Cancel pending Mobius query preview
            if (pendingMobiusQuery) {
                pendingMobiusQuery = null;
                const previews = document.querySelectorAll('.mq-label');
                if (previews.length) {
                    const last = previews[previews.length - 1];
                    last.textContent = '▸ Cancelled';
                    last.style.color = '#8d3a3a';
                    if (last.nextSibling) last.nextSibling.textContent = '';
                }
                return;
            }
            // 2. Fire any registered one-off Esc handler (e.g. Code: map prompt)
            if (window._escHandler) {
                window._escHandler();
                window._escHandler = null;
                return;
            }
            // 3. Clear the input box
            const input = document.getElementById('input');
            if (input && input.value.trim()) {
                input.value = '';
                return;
            }
        }

        const modelLabels = {
            groq: 'Groq', gemini: 'Gemini', mistral: 'Mistral',
            websearch: 'Groq+Tavily', system: 'System'
        };

        // ── Environment context ───────────────────────────────────────────────
        let mobiusContext = null;
        buildContextPayload().then(ctx => { mobiusContext = formatContextForPrompt(ctx); });

        async function buildContextPayload() {
            const ctx = {};
            const now = new Date();
            ctx.datetime   = now.toLocaleString('en-AU', { hour12: false });
            ctx.timezone   = Intl.DateTimeFormat().resolvedOptions().timeZone;
            const off = -now.getTimezoneOffset();
            const sign = off >= 0 ? '+' : '-';
            ctx.utc_offset = `UTC${sign}${String(Math.floor(Math.abs(off)/60)).padStart(2,'0')}:${String(Math.abs(off)%60).padStart(2,'0')}`;
            ctx.locale     = navigator.language || 'unknown';
            const ua = navigator.userAgent;
            ctx.os =
                /Windows NT 10/.test(ua)   ? 'Windows 10/11' :
                /Mac OS X/.test(ua)        ? 'macOS ' + (ua.match(/Mac OS X ([\d_]+)/)?.[1]?.replace(/_/g,'.') || '') :
                /Android/.test(ua)         ? 'Android ' + (ua.match(/Android ([\d.]+)/)?.[1] || '') :
                /iPhone|iPad/.test(ua)     ? 'iOS ' + (ua.match(/OS ([\d_]+)/)?.[1]?.replace(/_/g,'.') || '') :
                /Linux/.test(ua)           ? 'Linux' : 'Unknown';
            ctx.browser =
                /Edg\//.test(ua)     ? 'Edge '    + (ua.match(/Edg\/([\d.]+)/)?.[1]     || '') :
                /Chrome\//.test(ua)  ? 'Chrome '  + (ua.match(/Chrome\/([\d.]+)/)?.[1]  || '') :
                /Firefox\//.test(ua) ? 'Firefox ' + (ua.match(/Firefox\/([\d.]+)/)?.[1] || '') :
                /Safari\//.test(ua)  ? 'Safari '  + (ua.match(/Version\/([\d.]+)/)?.[1] || '') : 'Unknown';
            const isMobile = /Mobi|Android|iPhone|iPad/.test(ua);
            const isTablet = /iPad|Tablet/.test(ua) || (isMobile && Math.min(screen.width, screen.height) > 600);
            ctx.device_type = isTablet ? 'tablet' : isMobile ? 'mobile' : 'desktop';
            if (!isMobile) ctx.screen_resolution = `${screen.width}x${screen.height}`;
            ctx.dark_mode = window.matchMedia('(prefers-color-scheme: dark)').matches;
            ctx.online    = navigator.onLine;
            const conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
            if (conn) {
                if (conn.type)     ctx.connection_type = conn.type;
                if (conn.downlink) ctx.bandwidth_mbps  = conn.downlink;
                if (conn.rtt)      ctx.latency_ms      = conn.rtt;
            }
            try {
                const geo = await fetch('https://ipapi.co/json/', { signal: AbortSignal.timeout(3000) });
                if (geo.ok) {
                    const g = await geo.json();
                    if (!g.error) {
                        ctx.city = g.city; ctx.region = g.region;
                        ctx.country = g.country_name; ctx.currency = g.currency;
                    }
                }
            } catch { /* unavailable */ }
            Object.keys(ctx).forEach(k => ctx[k] === undefined && delete ctx[k]);
            return ctx;
        }

        function formatContextForPrompt(ctx) {
            if (!ctx || !Object.keys(ctx).length) return '';
            const lines = ['[User Environment]'];
            if (ctx.datetime)          lines.push(`Date/Time: ${ctx.datetime}`);
            if (ctx.timezone)          lines.push(`Timezone: ${ctx.timezone} (${ctx.utc_offset})`);
            if (ctx.locale)            lines.push(`Locale: ${ctx.locale}`);
            if (ctx.city)              lines.push(`Location: ${ctx.city}, ${ctx.region}, ${ctx.country}`);
            if (ctx.currency)          lines.push(`Currency: ${ctx.currency}`);
            if (ctx.os)                lines.push(`OS: ${ctx.os}`);
            if (ctx.browser)           lines.push(`Browser: ${ctx.browser}`);
            if (ctx.device_type)       lines.push(`Device: ${ctx.device_type}`);
            if (ctx.screen_resolution) lines.push(`Screen: ${ctx.screen_resolution}`);
            if (ctx.dark_mode != null) lines.push(`Dark mode: ${ctx.dark_mode}`);
            if (ctx.online != null)    lines.push(`Online: ${ctx.online}`);
            if (ctx.connection_type)   lines.push(`Connection: ${ctx.connection_type}`);
            if (ctx.bandwidth_mbps)    lines.push(`Bandwidth: ${ctx.bandwidth_mbps} Mbps`);
            if (ctx.latency_ms)        lines.push(`Latency: ${ctx.latency_ms} ms`);
            return lines.join('\n');
        }

        // ── Utilities ─────────────────────────────────────────────────────────
        function scrollToBottom() {
            const p = document.getElementById('chatPanel');
            p.scrollTop = p.scrollHeight;
        }
        function addDivider() {
            const p = document.getElementById('chatPanel');
            if (p.children.length > 0) {
                const hr = document.createElement('hr');
                hr.className = 'chat-divider';
                p.appendChild(hr);
            }
        }
        function escapeHtml(t) {
            return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        }
        window.markdownToHtml = function markdownToHtml(text) {
            text = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n');

            // Tables
            text = text.replace(/\|(.+)\|\n\|[-| :]+\|\n((?:\|.+\|\n?)+)/g, (match, header, rows) => {
                const ths = header.split('|').filter(s=>s.trim()).map(s=>`<th>${s.trim()}</th>`).join('');
                const trs = rows.trim().split('\n').map(row => {
                    const tds = row.split('|').filter(s=>s.trim()).map(s=>`<td>${s.trim()}</td>`).join('');
                    return `<tr>${tds}</tr>`;
                }).join('');
                return `<table><thead><tr>${ths}</tr></thead><tbody>${trs}</tbody></table>`;
            });

            // Code blocks first (protect content inside)
            const codeBlocks = [];
            text = text.replace(/```[\s\S]*?```/g, m => { codeBlocks.push(m); return `\x00CODE${codeBlocks.length-1}\x00`; });

            // Process line by line
            const lines = text.split('\n');
            const out   = [];
            let inList  = false;

            for (let i = 0; i < lines.length; i++) {
                let line = lines[i];

                // Headings
                if (/^### /.test(line))      { if (inList) { out.push('</ul>'); inList=false; } out.push('<h3>' + line.slice(4) + '</h3>'); continue; }
                if (/^## /.test(line))       { if (inList) { out.push('</ul>'); inList=false; } out.push('<h2>' + line.slice(3) + '</h2>'); continue; }
                if (/^# /.test(line))        { if (inList) { out.push('</ul>'); inList=false; } out.push('<h1>' + line.slice(2) + '</h1>'); continue; }

                // Horizontal rule
                if (/^---+$/.test(line.trim())) { if (inList) { out.push('</ul>'); inList=false; } out.push('<hr style="border:none;border-top:1px solid #c9bfae;margin:8px 0">'); continue; }

                // Bullet points (* or -)
                if (/^[\*\-] /.test(line)) {
                    if (!inList) { out.push('<ul>'); inList = true; }
                    out.push('<li>' + inline(line.slice(2)) + '</li>');
                    continue;
                }

                // Numbered list
                if (/^\d+\. /.test(line)) {
                    if (inList) { out.push('</ul>'); inList = false; }
                    out.push('<li>' + inline(line.replace(/^\d+\. /, '')) + '</li>');
                    continue;
                }

                // Close list on blank line or non-list content
                if (inList) { out.push('</ul>'); inList = false; }

                // Blank line
                if (line.trim() === '') { out.push('<br>'); continue; }

                out.push('<p style="margin:2px 0">' + inline(line) + '</p>');
            }

            if (inList) out.push('</ul>');

            // Restore code blocks
            let html = out.join('');
            html = html.replace(/\x00CODE(\d+)\x00/g, (_, i) => {
                const code = codeBlocks[i].replace(/```(\w+)?\n?/, '').replace(/```$/, '');
                return '<pre><code>' + code.replace(/</g,'&lt;') + '</code></pre>';
            });

            return html;

            function inline(s) {
                return s
                    .replace(/`([^`]+)`/g, '<code>$1</code>')
                    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
                    .replace(/\*(.+?)\*/g, '<em>$1</em>')
                    .replace(/_(.+?)_/g, '<em>$1</em>');
            }
        }
        function formatMobiusQuery(mq) {
            const lines = [
                `ASK: ${mq.ASK}`,
                `INSTRUCTIONS: ${mq.INSTRUCTIONS || 'Brief'}`,
                `HISTORY: [${(mq.HISTORY || []).length}]`,
                `QUERY: ${mq.QUERY}`,
                `FILES: [${(mq.FILES || []).filter(f => f.name !== 'environment.txt').length}]` + ((mq.FILES || []).filter(f => f.name !== 'environment.txt').length > 0 ? '\n' + mq.FILES.filter(f => f.name !== 'environment.txt').map(f => '  ' + f.name).join('\n') : ''),
                `CONTEXT: ${mobiusContext ? 'Yes' : 'None'}`
            ];
            return lines.join('\n');
        }

        // ── File handling ─────────────────────────────────────────────────────
        async function handleFileSelect(input) {
            for (const file of Array.from(input.files)) {
                const fd = new FormData();
                fd.append('file', file);
                try {
                    const res  = await fetch('/upload', { method:'POST', body:fd });
                    const data = await res.json();
                    if (data.error) { alert('Upload error: ' + data.error); continue; }
                    attachedFiles.push(data);
                    addFileChip(data);
                } catch (err) { alert('Upload failed: ' + err.message); }
            }
            input.value = '';
        }
        function addFileChip(f) {
            const chips = document.getElementById('fileChips');
            const chip  = document.createElement('div');
            chip.className = 'file-chip';
            chip.dataset.name = f.name;
            chip.innerHTML = `<span>${escapeHtml(f.name)}</span><span class="file-chip-remove" onclick="removeFile('${escapeHtml(f.name)}',this)">✕</span>`;
            chips.appendChild(chip);
        }
        function removeFile(name, el) {
            attachedFiles = attachedFiles.filter(f => f.name !== name);
            el.closest('.file-chip').remove();
        }

        // ── Context menu ──────────────────────────────────────────────────────
        function showContextMenu(e, session) {
            e.preventDefault();
            ctxSession = session;
            const menu = document.getElementById('contextMenu');
            menu.style.display = 'block';
            menu.style.left = e.clientX + 'px';
            menu.style.top  = e.clientY + 'px';
        }
        function hideContextMenu() {
            document.getElementById('contextMenu').style.display = 'none';
        }
        async function ctxAction(action) {
            hideContextMenu();
            if (!ctxSession) return;
            if (action === 'load') {
                loadSessionIntoChat(ctxSession);
            } else if (action === 'copy-summary') {
                navigator.clipboard.writeText(buildSummary(ctxSession)).then(() => alert('Summary copied!'));
            } else if (action === 'copy-full') {
                navigator.clipboard.writeText(buildFullText(ctxSession)).then(() => alert('Full chat copied!'));
            } else if (action === 'copy-context') {
                const summary  = buildSummary(ctxSession);
                const filename = 'context-' + new Date(ctxSession.started_at).toISOString().slice(0,10) + '.txt';
                const fd = new FormData();
                fd.append('file', new File([summary], filename, { type:'text/plain' }));
                try {
                    const res  = await fetch('/upload', { method:'POST', body:fd });
                    const data = await res.json();
                    if (data.error) { alert('Error: ' + data.error); return; }
                    attachedFiles.push(data);
                    addFileChip(data);
                } catch (err) { alert('Failed to attach context: ' + err.message); }
            }
        }
        function buildSummary(s) {
            let t = `Chat from ${new Date(s.started_at).toLocaleString()}\nTopic: ${s.title}\n\n`;
            s.messages.slice(0,3).forEach(m => t += `Q: ${m.question}\nA: ${m.answer}\n\n`);
            if (s.messages.length > 3) t += `[...${s.messages.length - 3} more exchanges]`;
            return t.trim();
        }
        function buildFullText(s) {
            let t = `Chat from ${new Date(s.started_at).toLocaleString()}\n${'─'.repeat(40)}\n\n`;
            s.messages.forEach(m => t += `Q: ${m.question}\nA: ${m.answer}\n\n`);
            return t.trim();
        }
        function loadSessionIntoChat(session) {
            const panel = document.getElementById('chatPanel');
            panel.innerHTML = '';
            chatHistory = [];
            const header = document.createElement('div');
            header.style.cssText = 'font-size:12px;color:#8d7c64;margin-bottom:12px;font-style:italic;';
            header.textContent = `📂 Loaded chat from ${new Date(session.started_at).toLocaleString()}`;
            panel.appendChild(header);
            for (const m of session.messages) {
                addDivider();
                const entry = document.createElement('div');
                entry.className = 'chat-entry';
                entry.innerHTML = `
                    <div class="chat-query">Q: ${escapeHtml(m.question)}</div>
                    <div class="chat-label">A:(${escapeHtml(modelLabels[m.model] || m.model)})</div>
                    <div class="chat-answer">${markdownToHtml(m.answer)}</div>`;
                panel.appendChild(entry);
                chatHistory.push({ role:'user', content:m.question });
                chatHistory.push({ role:'assistant', content:m.answer });
            }
            scrollToBottom();
        }

        // ── Chat history renderer (exposed to commands.js) ────────────────────
        window.renderChatHistoryList = function(sessions) {
            const panel = document.getElementById('chatPanel');
            addDivider();
            const wrapper = document.createElement('div');
            wrapper.innerHTML = `<div class="chat-label" style="margin-bottom:8px;">📋 Chat History (${sessions.length} sessions) — click to open, right-click for options</div>`;
            const list = document.createElement('div');
            list.className = 'chat-history-list';
            for (const session of sessions) {
                const item  = document.createElement('div');
                item.className = 'chat-history-item';
                const count = session.messages.length;
                item.innerHTML = `
                    <div class="chi-title">${escapeHtml(session.title)}</div>
                    <div class="chi-meta">${new Date(session.started_at).toLocaleString()} · ${count} exchange${count!==1?'s':''}</div>`;
                item.addEventListener('click', () => loadSessionIntoChat(session));
                item.addEventListener('contextmenu', e => showContextMenu(e, session));
                list.appendChild(item);
            }
            wrapper.appendChild(list);
            panel.appendChild(wrapper);
            scrollToBottom();
        };

        // ── Command output helper ─────────────────────────────────────────────
        function runCommandInPanel(text, command, args) {
            const panel = document.getElementById('chatPanel');
            addDivider();
            const entry = document.createElement('div');
            entry.className = 'chat-entry';
            const firstLine = text.split('\n')[0];
            const restLines = text.split('\n').slice(1).join('\n');
            entry.innerHTML = `<div class="chat-query">Q: ${escapeHtml(firstLine)}${restLines ? '<span style="font-weight:normal"> \n' + escapeHtml(restLines) + '</span>' : ''}</div>`;
            const output = document.createElement('div');
            output.className = 'mq-block';
            output.textContent = 'Running...';
            entry.appendChild(output);
            panel.appendChild(entry);
            scrollToBottom();
            const outputFn = msg => { output.textContent = msg; scrollToBottom(); };
            return { outputFn, outputEl: output };
        }

        // ── Main Ask handler ──────────────────────────────────────────────────
        async function handleAsk() {
            const userId = getAuth('mobius_user_id');
            if (!userId) { window.location.href = '/login'; return; }

            const text = document.getElementById('input').value.trim();
            if (!text && !pendingMobiusQuery) return;

            // Save to input history (deduplicate, most recent first)
            if (text && (inputHistory.length === 0 || inputHistory[0] !== text)) {
                inputHistory.unshift(text);
                if (inputHistory.length > 100) inputHistory.pop();
                saveInputHistory();
            }
            inputHistIdx   = -1;
            inputHistDraft = '';

            // If an audit is active and this is a plain message (not a command), record it in audit chat
            if (text && window._auditAppendUserMessage && !detectCommand(text)) {
                window._auditAppendUserMessage(text);
            }

            // ── Step 1: Intercept all non-AI commands immediately ─────────────
            // Access: needs special handling (synchronous user gesture for mobile)
            const detected = detectCommand(text);
            if (detected && detected.command === 'access') {
                const { outputFn } = runCommandInPanel(text, 'access', '');
                await handleAccess(outputFn);
                return;
            }
            // All other non-AI commands
            if (detected && detected.command !== 'ask') {
                const { outputFn, outputEl } = runCommandInPanel(text, detected.command, detected.args);
                await runCommand(detected.command, detected.args, outputFn, outputEl);
                return;
            }

            // ── Step 2: Pending query confirmation ────────────────────────────
            if (pendingMobiusQuery) {
                await executeQuery(userId);
                return;
            }

            // ── Step 3: Build query via /parse ────────────────────────────────
            await parseQuery(userId);
        }

        async function parseQuery(userId) {
            const text      = document.getElementById('input').value.trim();
            if (!text) return;
            const model     = getAskModel(text) || 'groq';
            const cleanText = text.replace(/^Ask:\s*\w+[.,]?\s*/i, '').trim() || text;
            const panel     = document.getElementById('chatPanel');

            addDivider();
            const entry = document.createElement('div');
            entry.className = 'chat-entry';
            const qFirst = text.split('\n')[0];
            const qRest  = text.split('\n').slice(1).join('\n');
            entry.innerHTML = `
                <div class="chat-query">Q: ${escapeHtml(qFirst)}${qRest ? '<span style="font-weight:normal"><br>' + escapeHtml(qRest) + '</span>' : ''}</div>
                <div class="mq-label">▸ Mobius Query (press Ask to send)</div>`;
            const mqPreview = document.createElement('div');
            mqPreview.className = 'mq-block';
            mqPreview.textContent = 'Building...';
            entry.appendChild(mqPreview);

            // Show image previews
            for (const f of attachedFiles) {
                if (f.mimeType?.startsWith('image/')) {
                    const img = document.createElement('img');
                    img.className = 'img-thumb';
                    img.src = `data:${f.mimeType};base64,${f.base64}`;
                    entry.appendChild(img);
                }
            }
            panel.appendChild(entry);
            scrollToBottom();

            // Inject code session context if active
            let effectiveModel = model;
            let effectiveContext = mobiusContext; // always just environment data
            let forceInstructionMode = null;
            let codeSessionFile = null;           // virtual file for code session content
            const codeSession = window.getCodeSession ? window.getCodeSession() : null;
            if (codeSession) {
                effectiveModel       = 'gemini';
                forceInstructionMode = 'Code';

                // Parse audit sections — exclude REPO/SCAN (already in code index)
                let auditPlan = '', auditStatus = '', auditChat = '';
                if (codeSession.auditContent) {
                    const auditplanMatch = codeSession.auditContent.match(/^## AUDITPLAN\s*\n([\s\S]*?)(?=^## |$)/m);
                    const statusMatch    = codeSession.auditContent.match(/^## STATUS\s*\n([\s\S]*?)(?=^## |$)/m);
                    const chatMatch      = codeSession.auditContent.match(/^## CHAT\s*\n([\s\S]*)/m);
                    auditPlan   = auditplanMatch ? auditplanMatch[1].trim() : '';
                    auditStatus = statusMatch    ? statusMatch[1].trim()    : '';
                    auditChat   = chatMatch      ? chatMatch[1].trim()      : '';
                }

                // Pre-append current user message so Gemini sees the full conversation
                const now = new Date().toLocaleString('en-AU');
                const auditChatWithUser = auditChat
                    ? auditChat + '\n\n[' + now + '] YOU\n' + cleanText
                    : '[' + now + '] YOU\n' + cleanText;

                // Build composite session document
                const sessionDoc =
                    '# Code Session: ' + codeSession.projectName + '\n\n' +
                    (codeSession.mapContent  ? '=== PROJECT MAP ===\n'  + codeSession.mapContent  + '\n\n' : '') +
                    (codeSession.repoContent ? '=== CODE INDEX ===\n'   + codeSession.repoContent + '\n\n' : '') +
                    (auditPlan               ? '=== AUDIT PLAN ===\n'   + auditPlan               + '\n\n' : '') +
                    (auditStatus             ? '=== AUDIT STATUS ===\n' + auditStatus             + '\n\n' : '') +
                    '=== AUDIT CHAT ===\n' + auditChatWithUser;

                // Encode as a virtual file attachment
                codeSessionFile = {
                    name:     codeSession.projectName.toLowerCase().replace(/[^a-z0-9_]/g, '_') + '_session.txt',
                    mimeType: 'text/plain',
                    base64:   btoa(unescape(encodeURIComponent(sessionDoc))),
                    size:     sessionDoc.length
                };
            }

        try {
                const res  = await fetch('/parse', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text:cleanText, model:effectiveModel, history:chatHistory, forceInstructionMode })
                });
                const data = await res.json();
                pendingMobiusQuery = data.mobius_query;
                // Build environment context as a virtual file
                const envFile = mobiusContext ? {
                    name:     'environment.txt',
                    mimeType: 'text/plain',
                    base64:   btoa(unescape(encodeURIComponent(mobiusContext))),
                    size:     mobiusContext.length
                } : null;

                pendingMobiusQuery.FILES = [
                    ...(envFile         ? [envFile]         : []),
                    ...(codeSessionFile ? [codeSessionFile] : []),
                    ...attachedFiles
                ];
                // Attach focused file content if active
                if (window.getFocusFile && window.getFocusFile()) {
                    const ff = window.getFocusFile();
                    const focusAttachment = {
                        name: ff.name,
                        mimeType: 'text/plain',
                        base64: btoa(unescape(encodeURIComponent(ff.content || ''))),
                        size: ff.content ? ff.content.length : 0
                    };
                    pendingMobiusQuery.FILES.unshift(focusAttachment);
                }
                if (attachedFiles.some(f => f.mimeType?.startsWith('image/'))) {
                    pendingMobiusQuery.ASK = 'gemini';
                }
                mqPreview.textContent = formatMobiusQuery(pendingMobiusQuery);
                scrollToBottom();
            } catch (err) {
                mqPreview.textContent = 'Error: ' + err.message;
                pendingMobiusQuery = null;
            }
        }

        async function executeQuery(userId) {
            const panel = document.getElementById('chatPanel');
            const mq    = pendingMobiusQuery;
            pendingMobiusQuery = null;
            attachedFiles = [];
            document.getElementById('fileChips').innerHTML = '';

            const modelLabel  = mq.ASK; // full name now comes from _ai.js MODEL_FULL_NAMES
            const answerLabel = document.createElement('div');
            answerLabel.className = 'chat-label';
            answerLabel.textContent = `A:(${modelLabel})`;
            const answerDiv = document.createElement('div');
            answerDiv.className = 'chat-answer thinking';
            answerDiv.textContent = 'Thinking...';
            const wrapper = document.createElement('div');
            wrapper.appendChild(answerLabel);
            wrapper.appendChild(answerDiv);
            panel.appendChild(wrapper);
            scrollToBottom();

            // ── Local AI path (Ollama or WebLLM) ───────────────────────────────
            if (mq.ASK === 'qwen' || mq.ASK === 'deepseek') {
                try {
                    const ollamaModel = mq.ASK === 'qwen' ? 'qwen2.5-coder:7b' : 'deepseek-r1:7b';
                    const modelLabel  = mq.ASK === 'qwen' ? 'Ollama Qwen 2.5 Coder (local)' : 'Ollama DeepSeek R1 7B (local)';
                    answerDiv.textContent = '⚡ Connecting to Ollama...';
                    const r = await fetch('http://localhost:11434/v1/chat/completions', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            model: ollamaModel,
                            messages: [...(mq.HISTORY || []), { role: 'user', content: mq.QUERY }]
                        })
                    });
                    if (!r.ok) throw new Error('Ollama returned ' + r.status);
                    const data    = await r.json();
                    const content = data.choices?.[0]?.message?.content;
                    if (!content) throw new Error('No content from Ollama');
                    answerDiv.className     = 'chat-answer';
                    answerDiv.innerHTML     = markdownToHtml(content);
                    answerLabel.textContent = `A:(${modelLabel})`;
                    addResponseToolbar(wrapper, content);
                    chatHistory.push({ role: 'user',      content: mq.QUERY });
                    chatHistory.push({ role: 'assistant', content });
                    document.getElementById('input').value = '';
                    scrollToBottom();
                } catch (err) {
                    answerDiv.className   = 'chat-answer';
                    answerDiv.textContent = '❌ ' + (err.message.includes('Failed to fetch') || err.message.includes('Ollama')
                        ? 'Ollama unavailable. Is it running? Start it with start-ollama.bat'
                        : err.message);
                }
                return;
            }

            if (mq.ASK === 'webllm') {
                try {
                    const messages = [
                        ...(mq.HISTORY || []),
                        { role: 'user', content: mq.QUERY }
                    ];
                    const { reply, modelUsed } = await window.askLocal(
                        messages,
                        msg => { answerDiv.textContent = msg; scrollToBottom(); }
                    );
                    answerDiv.className   = 'chat-answer';
                    answerDiv.innerHTML   = markdownToHtml(reply);
                    answerLabel.textContent = `A:(${modelUsed})`;
                    addResponseToolbar(wrapper, reply);
                    chatHistory.push({ role: 'user',      content: mq.QUERY });
                    chatHistory.push({ role: 'assistant', content: reply });
                    document.getElementById('input').value = '';
                    scrollToBottom();
                } catch (err) {
                    answerDiv.className   = 'chat-answer';
                    answerDiv.textContent = '❌ ' + err.message;
                }
                return;
            }

            try {
                const res  = await fetch('/ask', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ mobius_query:mq, userId, session_id: currentSessionId })
                });
                const data = await res.json();
                const reply     = data.reply || data.error;
                const usedModel = data.modelUsed || mq.ASK;
                answerDiv.className = 'chat-answer';
                answerDiv.innerHTML = markdownToHtml(reply);
                const tokenInfo = (data.tokensIn || data.tokensOut)
                    ? '  ·  ' + (data.tokensIn ? data.tokensIn.toLocaleString() + ' in' : '') +
                      (data.tokensIn && data.tokensOut ? ' / ' : '') +
                      (data.tokensOut ? data.tokensOut.toLocaleString() + ' out' : '') + ' tokens'
                    : '';
                answerLabel.textContent = `A:(${modelLabels[usedModel] || usedModel})${tokenInfo}`;
                addResponseToolbar(wrapper, reply);
                chatHistory.push({ role:'user', content:mq.QUERY });
                chatHistory.push({ role:'assistant', content:reply });
                document.getElementById('input').value = '';
                scrollToBottom();
            } catch (err) {
                answerDiv.className = 'chat-answer';
                answerDiv.textContent = 'Error: ' + err.message;
            }
        }

        // ── New Chat ──────────────────────────────────────────────────────────
        window.newChat = function(topic) {
            // Clear chat panel and reset history
            document.getElementById('chatPanel').innerHTML = '';
            chatHistory = [];
            currentSessionId = generateSessionId(); // new session = new UUID
            attachedFiles = [];
            document.getElementById('fileChips').innerHTML = '';
            pendingMobiusQuery = null;
            currentNavIndex = -1;

            if (topic) {
                // Show a subtle header, then fire the topic as a new query
                const header = document.createElement('div');
                header.style.cssText = 'font-size:12px;color:#8d7c64;margin-bottom:12px;font-style:italic;';
                header.textContent = '🆕 New chat: ' + topic;
                document.getElementById('chatPanel').appendChild(header);
                document.getElementById('input').value = topic;
                handleAsk();
            } else {
                const header = document.createElement('div');
                header.style.cssText = 'font-size:12px;color:#8d7c64;margin-bottom:12px;font-style:italic;';
                header.textContent = '🆕 New chat started';
                document.getElementById('chatPanel').appendChild(header);
                document.getElementById('input').value = '';
                document.getElementById('input').focus();
            }
        };

        // ── Response toolbar ───────────────────────────────────────────────
        function addResponseToolbar(entry, replyText) {
            const toolbar = document.createElement('div');
            toolbar.className = 'resp-toolbar';

            // Copy
            const copyBtn = document.createElement('button');
            copyBtn.className = 'resp-btn';
            copyBtn.title = 'Copy response';
            copyBtn.textContent = '⧉';
            copyBtn.onclick = () => {
                navigator.clipboard.writeText(replyText).then(() => {
                    copyBtn.textContent = '✓';
                    setTimeout(() => { copyBtn.textContent = '⧉'; }, 1500);
                });
            };

            // Upvote
            const upvote = document.createElement('button');
            upvote.className = 'resp-btn';
            upvote.title = 'Good response';
            upvote.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>';
            upvote.onclick = () => {
                const active = upvote.classList.toggle('active-up');
                if (active) upvote.querySelector('svg').setAttribute('fill', 'currentColor');
                else upvote.querySelector('svg').setAttribute('fill', 'none');
                downvote.classList.remove('active-down');
                downvote.querySelector('svg').setAttribute('fill', 'none');
            };

            // Downvote
            const downvote = document.createElement('button');
            downvote.className = 'resp-btn';
            downvote.title = 'Poor response';
            downvote.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3H10z"/><path d="M17 2h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>';
            downvote.onclick = () => {
                const active = downvote.classList.toggle('active-down');
                if (active) downvote.querySelector('svg').setAttribute('fill', 'currentColor');
                else downvote.querySelector('svg').setAttribute('fill', 'none');
                upvote.classList.remove('active-up');
                upvote.querySelector('svg').setAttribute('fill', 'none');
            };

            // Up nav
            const upBtn = document.createElement('button');
            upBtn.className = 'resp-btn';
            upBtn.title = 'Previous';
            upBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18,15 12,9 6,15"/></svg>';
            upBtn.onclick = () => navigateChat(-1);

            // Down nav
            const downBtn = document.createElement('button');
            downBtn.className = 'resp-btn';
            downBtn.title = 'Next';
            downBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6,9 12,15 18,9"/></svg>';
            downBtn.onclick = () => navigateChat(1);

            toolbar.appendChild(copyBtn);
            toolbar.appendChild(upvote);
            toolbar.appendChild(downvote);
            toolbar.appendChild(upBtn);
            toolbar.appendChild(downBtn);
            entry.appendChild(toolbar);
        }

        // ── Navigation & search ───────────────────────────────────────────────
        function getQueryEntries() { return Array.from(document.querySelectorAll('.chat-entry')); }
        function navigateChat(dir) {
            const entries = getQueryEntries();
            if (!entries.length) return;
            currentNavIndex = Math.max(0, Math.min(entries.length-1, currentNavIndex+dir));
            entries[currentNavIndex].scrollIntoView({ behavior:'smooth', block:'start' });
        }
        function searchChat(term) {
            const panel = document.getElementById('chatPanel');
            panel.querySelectorAll('mark').forEach(m => m.replaceWith(document.createTextNode(m.textContent)));
            panel.normalize();
            if (!term.trim()) return;
            const walker = document.createTreeWalker(panel, NodeFilter.SHOW_TEXT);
            const matches = [];
            let node;
            while (node = walker.nextNode()) {
                if (node.textContent.toLowerCase().includes(term.toLowerCase())) matches.push(node);
            }
            matches.forEach(node => {
                const regex = new RegExp(`(${term.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi');
                const span  = document.createElement('span');
                span.innerHTML = node.textContent.replace(regex, '<mark style="background:#c8b89a;color:#2a2a2a;">$1</mark>');
                node.replaceWith(span);
            });
            const first = panel.querySelector('mark');
            if (first) first.scrollIntoView({ behavior:'smooth', block:'center' });
        }

        // ── Google auto-connect ───────────────────────────────────────────────
        // Handle returning from Google OAuth
        if (window.location.search.includes('google_email')) {
            const params = new URLSearchParams(window.location.search);
            const googleEmail = params.get('google_email');
            if (googleEmail) {
                setAuth('mobius_username', googleEmail);
                setAuth('mobius_google_connected', '1');
                document.getElementById('userLabel').textContent = 'User: ' + googleEmail;
            }
            history.replaceState({}, '', '/');
        }

        // Handle returning from Dropbox OAuth
        if (window.location.search.includes('dropbox_connected')) {
            history.replaceState({}, '', '/');
        }

        // ── Sync indicator helpers ─────────────────────────────────────
        function setSyncStatus(text, color) {
            const el = document.getElementById('syncIndicator');
            if (!el) return;
            el.textContent = text;
            el.style.color = color || '#8d7c64';
            el.title       = text;
        }
        window.setSyncStatus = setSyncStatus;

        // ── Background sync ──────────────────────────────────────────────
        async function backgroundSync(userId, incremental) {
            setSyncStatus('⟳ syncing', '#a06800');
            try {
                const body = { userId, type: 'all' };
                if (incremental) body.since = new Date(Date.now() - 5 * 60 * 1000).toISOString();
                const res  = await fetch('/api/sync', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify(body)
                });
                const data = await res.json();
                if (data.error) { setSyncStatus('⚠ sync error', '#8d3a3a'); return; }
                const now = new Date().toLocaleTimeString('en-AU', { hour: '2-digit', minute: '2-digit' });
                setSyncStatus('✓ ' + now, '#4a7c4e');
            } catch {
                setSyncStatus('⚠ offline', '#8d3a3a');
            }
        }

        // ── 5-minute incremental poll ──────────────────────────────────────
        let syncInterval = null;
        function startSyncPoll(userId) {
            if (syncInterval) return;
            syncInterval = setInterval(() => backgroundSync(userId, true), 5 * 60 * 1000);
        }

        // Auto-connect personal Google account (first login only)
        async function autoConnectGoogle() {
            const userId = getAuth('mobius_user_id');
            if (!userId) return;
            if (getAuth('mobius_google_connected') === '1') return;
            if (sessionStorage.getItem('mobius_google_attempted') === '1') return;
            sessionStorage.setItem('mobius_google_attempted', '1');
            window.location.href = '/auth/google?userId=' + userId +
                '&label=personal' +
                '&returnTo=' + encodeURIComponent(window.location.origin);
        }

        // ── Startup sequence ──────────────────────────────────────────────
        (async () => {
            const userId = getAuth('mobius_user_id');
            if (!userId) return;
            await autoConnectGoogle();
            backgroundSync(userId, false);   // full sync on startup, non-blocking
            startSyncPoll(userId);           // start 5-min incremental poll
        })();
    </script>

    <script type="module">
